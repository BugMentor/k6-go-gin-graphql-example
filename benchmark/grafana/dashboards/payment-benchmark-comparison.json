{
  "uid": "payment-service-monitor",
  "title": "Payment Service - Real-Time Monitoring (Go)",
  "description": "Production monitoring dashboard for Go GraphQL Payment Service. Memory, goroutines, request latency, throughput, and error rates.",
  "tags": ["payment", "go", "graphql", "monitoring"],
  "timezone": "browser",
  "editable": true,
  "refresh": "10s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "panels": [],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Mimir",
          "value": "PAE45454D0EDB9216"
        }
      }
    ]
  },
  "rows": [
    {
      "title": "Auto-Scaling (HPA)",
      "collapse": false,
      "panels": [
        {
          "title": "Pod Count (HPA Scaling)",
          "type": "timeseries",
          "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
          "targets": [
            {
              "expr": "count(up{app=\"payment-service\",backend=\"go-graphql\"})",
              "legendFormat": "Running Pods",
              "refId": "A",
              "exemplar": false
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 5 },
                  { "color": "red", "value": 15 }
                ]
              }
            }
          },
          "maxDataPoints": 300,
          "interval": "10s"
        },
        {
          "title": "Goroutines Count (Aggregate)",
          "type": "timeseries",
          "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
          "targets": [
            {
              "expr": "avg(go_goroutines{app=\"payment-service\",backend=\"go-graphql\"})",
              "legendFormat": "Mean Goroutines",
              "refId": "A",
              "exemplar": false
            },
            {
              "expr": "5000",
              "legendFormat": "Warning (5000)",
              "refId": "B",
              "exemplar": false
            },
            {
              "expr": "10000",
              "legendFormat": "Critical (10000)",
              "refId": "C",
              "exemplar": false
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 5000 },
                  { "color": "red", "value": 10000 }
                ]
              }
            }
          },
          "maxDataPoints": 300,
          "interval": "10s"
        },
        {
          "title": "Go Heap Memory (Aggregate)",
          "type": "timeseries",
          "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
          "targets": [
            {
              "expr": "avg(go_memstats_heap_inuse_bytes{app=\"payment-service\",backend=\"go-graphql\"}) / avg(go_memstats_heap_sys_bytes{app=\"payment-service\",backend=\"go-graphql\"}) * 100",
              "legendFormat": "Mean Heap %",
              "refId": "A",
              "exemplar": false
            },
            {
              "expr": "60",
              "legendFormat": "RAM Upscale (60%)",
              "refId": "B",
              "exemplar": false
            },
            {
              "expr": "30",
              "legendFormat": "RAM Downscale (30%)",
              "refId": "C",
              "exemplar": false
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 40 },
                  { "color": "red", "value": 60 }
                ]
              }
            }
          },
          "maxDataPoints": 300,
          "interval": "10s"
        }
      ]
    },
    {
      "title": "Resource Consumption",
      "collapse": false,
      "panels": [
        {
          "title": "Goroutines per Instance",
          "type": "timeseries",
          "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
          "targets": [
            {
              "expr": "go_goroutines{app=\"payment-service\",backend=\"go-graphql\"}",
              "legendFormat": "{{pod}}",
              "refId": "A",
              "exemplar": false
            },
            {
              "expr": "5000",
              "legendFormat": "Warning (5000)",
              "refId": "B",
              "exemplar": false
            },
            {
              "expr": "10000",
              "legendFormat": "Critical (10000)",
              "refId": "C",
              "exemplar": false
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 5000 },
                  { "color": "red", "value": 10000 }
                ]
              }
            }
          },
          "maxDataPoints": 300,
          "interval": "10s"
        },
        {
          "title": "Go Heap Memory %",
          "type": "timeseries",
          "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
          "targets": [
            {
              "expr": "(go_memstats_heap_inuse_bytes{app=\"payment-service\",backend=\"go-graphql\"} / go_memstats_heap_sys_bytes{app=\"payment-service\",backend=\"go-graphql\"}) * 100",
              "legendFormat": "{{pod}} - Heap %",
              "refId": "A",
              "exemplar": false
            },
            {
              "expr": "60",
              "legendFormat": "RAM Upscale (60%)",
              "refId": "B",
              "exemplar": false
            },
            {
              "expr": "30",
              "legendFormat": "RAM Downscale (30%)",
              "refId": "C",
              "exemplar": false
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 40 },
                  { "color": "red", "value": 60 }
                ]
              }
            }
          },
          "maxDataPoints": 300,
          "interval": "10s"
        },
        {
          "title": "Active Requests & DB Connections",
          "type": "timeseries",
          "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
          "targets": [
            {
              "expr": "http_server_requests_active{app=\"payment-service\",backend=\"go-graphql\"}",
              "legendFormat": "Active HTTP Requests",
              "refId": "A",
              "exemplar": false
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0
            }
          },
          "maxDataPoints": 300,
          "interval": "10s"
        },
        {
          "title": "Request Rate by Endpoint",
          "type": "timeseries",
          "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
          "targets": [
            {
              "expr": "sum(rate(http_server_requests_total{app=\"payment-service\",backend=\"go-graphql\"}[$__rate_interval])) by (endpoint)",
              "legendFormat": "{{endpoint}} - RPS",
              "refId": "A",
              "exemplar": false
            },
            {
              "expr": "sum(rate(http_server_requests_total{app=\"payment-service\",backend=\"go-graphql\",status=~\"5..\"}[$__rate_interval])) / sum(rate(http_server_requests_total{app=\"payment-service\",backend=\"go-graphql\"}[$__rate_interval])) * 100",
              "legendFormat": "Error %",
              "refId": "B",
              "exemplar": false
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "color": { "mode": "palette-classic" }
            }
          },
          "maxDataPoints": 300,
          "interval": "10s"
        }
      ]
    },
    {
      "title": "OOM & Cluster Resources",
      "collapse": false,
      "panels": [
        {
          "title": "OOM Kills (Memory Failures)",
          "type": "timeseries",
          "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
          "targets": [
            {
              "expr": "container_memory_failures_total{container=\"payment-service\"}",
              "legendFormat": "{{pod}}",
              "refId": "A",
              "exemplar": false
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "min": 0,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "red", "value": 1 }
                ]
              }
            }
          },
          "maxDataPoints": 300,
          "interval": "10s"
        },
        {
          "title": "Mean Cluster CPU Usage",
          "type": "timeseries",
          "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
          "targets": [
            {
              "expr": "sum(rate(container_cpu_usage_seconds_total[5m])) by (node) / sum(machine_cpu_cores) by (node) * 100",
              "legendFormat": "{{node}}",
              "refId": "A",
              "exemplar": false
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 60 },
                  { "color": "red", "value": 80 }
                ]
              }
            }
          },
          "maxDataPoints": 300,
          "interval": "10s"
        },
        {
          "title": "Mean Cluster RAM Usage",
          "type": "timeseries",
          "gridPos": { "x": 16, "y": 0, "w": 8, "h": 8 },
          "targets": [
            {
              "expr": "sum(container_memory_working_set_bytes) by (node) / sum(machine_memory_bytes) by (node) * 100",
              "legendFormat": "{{node}}",
              "refId": "A",
              "exemplar": false
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 60 },
                  { "color": "red", "value": 85 }
                ]
              }
            }
          },
          "maxDataPoints": 300,
          "interval": "10s"
        }
      ]
    },
    {
      "title": "Latency",
      "collapse": true,
      "panels": [
        {
          "title": "Requests Per Second",
          "type": "timeseries",
          "gridPos": { "x": 0, "y": 8, "w": 6, "h": 8 },
