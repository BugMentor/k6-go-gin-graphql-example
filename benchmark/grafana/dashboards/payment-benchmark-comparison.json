          "interval": "10s"
        }
      ]
    },
    {
      "title": "Throughput",
      "collapse": true,
      "panels": [
        {
          "title": "Total Requests Per Second",
          "type": "timeseries",
          "gridPos": { "x": 0, "y": 56, "w": 8, "h": 8 },
          "targets": [
            {
              "expr": "sum(rate(http_server_requests_total{app=\"payment-service\",backend=\"go-graphql\"}[$__rate_interval]))",
              "legendFormat": "Total RPS",
              "refId": "A",
              "exemplar": false
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "reqps",
              "min": 0
            }
          },
          "maxDataPoints": 300,
          "interval": "10s"
        },
        {
          "title": "Avg Response Time by Endpoint",
          "type": "timeseries",
          "gridPos": { "x": 8, "y": 56, "w": 8, "h": 8 },
          "targets": [
            {
              "expr": "rate(http_server_requests_seconds_sum{app=\"payment-service\",backend=\"go-graphql\"}[$__rate_interval]) / rate(http_server_requests_seconds_count{app=\"payment-service\",backend=\"go-graphql\"}[$__rate_interval]) * 1000",
              "legendFormat": "{{endpoint}} - avg ms",
              "refId": "A",
              "exemplar": false
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ms",
              "min": 0,
              "color": { "mode": "palette-classic" }
            }
          },
          "maxDataPoints": 300,
          "interval": "10s"
        },
        {
          "title": "RPS per Core",
          "type": "stat",
          "gridPos": { "x": 16, "y": 56, "w": 8, "h": 8 },
          "targets": [
            {
              "expr": "sum(rate(http_server_requests_total{app=\"payment-service\",backend=\"go-graphql\"}[$__rate_interval])) / scalar(go_goroutines{app=\"payment-service\",backend=\"go-graphql\"}) * 1000",
              "legendFormat": "RPS/Kgoroutine",
              "refId": "A",
              "exemplar": false
            }
          ],
          "fieldConfig": {
            "defaults": {
              "color": { "mode": "thresholds" },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "red", "value": null },
                  { "color": "yellow", "value": 10 },
                  { "color": "green", "value": 100 }
                ]
              }
            }
          },
          "maxDataPoints": 300,
          "interval": "10s"
        }
      ]
    }
  ]
}
