            {
              "expr": "sum(rate(http_server_requests_total{app=\"payment-service\",backend=\"go-graphql\"}[$__rate_interval])) by (endpoint)",
              "legendFormat": "{{endpoint}}",
              "refId": "A",
              "exemplar": false
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "reqps",
              "min": 0,
              "color": { "mode": "palette-classic" }
            }
          },
          "maxDataPoints": 300,
          "interval": "10s"
        },
        {
          "title": "Avg Response Time",
