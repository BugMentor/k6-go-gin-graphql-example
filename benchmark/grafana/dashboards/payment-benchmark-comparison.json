{
  "uid": "payment-service-monitor",
  "title": "Payment Service - Real-Time Monitoring (Go)",
  "tags": ["go", "gin", "graphql", "payments"],
  "style": "dark",
  "timezone": "browser",
  "editable": true,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "Mimir",
          "value": "Mimir"
        },
        "hide": 0,
        "label": "Datasource",
        "name": "prometheus",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "rows": [
    {
      "title": "Auto-Scaling (HPA)",
      "panels": [
        {
          "title": "Pod Count",
          "type": "stat",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "count(up{app=\"payment-service\"})",
              "legendFormat": "Pods"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "red", "value": null},
                  {"color": "green", "value": 2}
                ]
              },
              "mappings": [],
              "unit": "short"
            }
          },
          "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
        },
        {
          "title": "CPU Usage (Aggregate %)",
          "type": "gauge",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "avg(rate(container_cpu_usage_seconds_total{container=\"payment-service\"}[1m]) / on(pod) group_left kube_pod_container_resource_limits{resource=\"cpu\"}) * 100",
              "legendFormat": "CPU %"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "yellow", "value": 60},
                  {"color": "red", "value": 80}
                ]
              },
              "unit": "percent",
              "min": 0,
              "max": 100
            }
          },
          "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
        },
        {
          "title": "Go Heap Memory (Aggregate MB)",
          "type": "gauge",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "avg(go_memstats_heap_inuse_bytes{app=\"payment-service\"}) / 1048576",
              "legendFormat": "Heap In-Use MB"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "yellow", "value": 768},
                  {"color": "red", "value": 896}
                ]
              },
              "unit": "decmbytes"
            }
          },
          "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0}
        },
        {
          "title": "Goroutines (Aggregate)",
          "type": "stat",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "sum(go_goroutines{app=\"payment-service\"})",
              "legendFormat": "Goroutines"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "orange", "value": 1000},
                  {"color": "red", "value": 5000}
                ]
              },
              "unit": "short"
            }
          },
          "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0}
        }
      ]
    },
    {
      "title": "Resource Consumption",
      "panels": [
        {
          "title": "CPU Usage per Pod (%)",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "rate(container_cpu_usage_seconds_total{container=\"payment-service\"}[1m]) / on(pod) group_left kube_pod_container_resource_limits{resource=\"cpu\"} * 100",
              "legendFormat": "{{pod}} CPU %"
            },
            {
              "expr": "80",
              "legendFormat": "Upscale (80%)"
            },
            {
              "expr": "40",
              "legendFormat": "Downscale (40%)"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100
            }
          },
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
        },
        {
          "title": "Go Heap Memory per Pod (%)",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "(go_memstats_heap_inuse_bytes{app=\"payment-service\"} / go_memstats_heap_sys_bytes{app=\"payment-service\"}) * 100",
              "legendFormat": "{{pod}} Heap %"
            },
            {
              "expr": "60",
              "legendFormat": "Upscale (60%)"
            },
            {
              "expr": "30",
              "legendFormat": "Downscale (30%)"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100
            }
          },
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
        }
      ]
    },
    {
      "title": "OOM & Cluster Resources",
      "panels": [
        {
          "title": "Go Memory OOM Kills",
          "type": "stat",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "increase(container_oom_events_total{container=\"payment-service\"}[5m])",
              "legendFormat": "OOM Kills (5m)"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "yellow", "value": 1},
                  {"color": "red", "value": 2}
                ]
              }
            }
          },
          "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
        },
        {
          "title": "Cluster CPU %",
          "type": "gauge",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "avg(rate(container_cpu_usage_seconds_total[1m])) * 100",
              "legendFormat": "Cluster CPU"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "red", "value": 80}
                ]
              }
            }
          },
          "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
        },
        {
          "title": "Cluster RAM %",
          "type": "gauge",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "avg(container_memory_usage_bytes / container_spec_memory_limit_bytes) * 100",
              "legendFormat": "Cluster RAM"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "red", "value": 80}
                ]
              }
            }
          },
          "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0}
        }
      ]
    },
    {
      "title": "Latency",
      "panels": [
        {
          "title": "Requests Per Second",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "sum(rate(http_server_requests_total{app=\"payment-service\"}[1m]))",
              "legendFormat": "Total RPS"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "reqps"
            }
          },
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
        },
        {
          "title": "P50 / P90 / P95 / P99 / Max (ms)",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{app=\"payment-service\"}[1m])) * 1000",
              "legendFormat": "P50"
            },
            {
              "expr": "histogram_quantile(0.90, rate(http_server_requests_seconds_bucket{app=\"payment-service\"}[1m])) * 1000",
              "legendFormat": "P90"
            },
            {
              "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{app=\"payment-service\"}[1m])) * 1000",
              "legendFormat": "P95"
            },
            {
              "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{app=\"payment-service\"}[1m])) * 1000",
              "legendFormat": "P99"
            },
            {
              "expr": "max(rate(http_server_requests_seconds_bucket{app=\"payment-service\"}[1m])) * 1000",
              "legendFormat": "Max"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ms"
            }
          },
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
        }
      ]
    },
    {
      "title": "Errors & Reliability",
      "panels": [
        {
          "title": "Error Rate (5xx %)",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "sum(rate(http_server_requests_total{app=\"payment-service\",status=~\"5..\"}[1m])) / sum(rate(http_server_requests_total{app=\"payment-service\"}[1m])) * 100",
              "legendFormat": "Error Rate %"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100
            }
          },
          "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
        },
        {
          "title": "Status Code Distribution",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "sum(rate(http_server_requests_total{app=\"payment-service\",status=~\"2..\"}[1m]))",
              "legendFormat": "2xx"
            },
            {
              "expr": "sum(rate(http_server_requests_total{app=\"payment-service\",status=~\"4..\"}[1m]))",
              "legendFormat": "4xx"
            },
            {
              "expr": "sum(rate(http_server_requests_total{app=\"payment-service\",status=~\"5..\"}[1m]))",
              "legendFormat": "5xx"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "reqps"
            }
          },
          "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
        },
        {
          "title": "Active Requests",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "http_server_requests_active{app=\"payment-service\"}",
              "legendFormat": "Active"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short"
            }
          },
          "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}
        },
        {
          "title": "Query Errors",
          "type": "stat",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "increase(http_server_requests_total{app=\"payment-service\",status=~\"5..\"}[5m])",
              "legendFormat": "Errors (5m)"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "yellow", "value": 10},
                  {"color": "red", "value": 50}
                ]
              }
            }
          },
          "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
        }
      ]
    },
    {
      "title": "Go Runtime & Database",
      "panels": [
        {
          "title": "Goroutines",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "go_goroutines{app=\"payment-service\"}",
              "legendFormat": "{{pod}}"
            }
          ],
          "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0}
        },
        {
          "title": "Go Heap Memory",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "go_memstats_heap_inuse_bytes{app=\"payment-service\"}",
              "legendFormat": "{{pod}} Heap In-Use"
            },
            {
              "expr": "go_memstats_heap_idle_bytes{app=\"payment-service\"}",
              "legendFormat": "{{pod}} Heap Idle"
            },
            {
              "expr": "go_memstats_heap_sys_bytes{app=\"payment-service\"}",
              "legendFormat": "{{pod}} Heap Sys"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "bytes"
            }
          },
          "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0}
        },
        {
          "title": "Go GC Duration",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "rate(go_gc_duration_seconds_sum{app=\"payment-service\"}[1m])",
              "legendFormat": "{{pod}} GC/s"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "s"
            }
          },
          "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0}
        },
        {
          "title": "Go Stack Memory",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "go_memstats_stack_inuse_bytes{app=\"payment-service\"}",
              "legendFormat": "{{pod}} Stack"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "bytes"
            }
          },
          "gridPos": {"h": 6, "w": 8, "x": 0, "y": 6}
        },
        {
          "title": "Go Memory Allocation Rate",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "rate(go_memstats_alloc_bytes_total{app=\"payment-service\"}[1m])",
              "legendFormat": "{{pod}} Alloc/s"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "Bps"
            }
          },
          "gridPos": {"h": 6, "w": 8, "x": 8, "y": 6}
        },
        {
          "title": "DB Connection Pool",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "pgxpool_total_conns{app=\"payment-service\"}",
              "legendFormat": "Total"
            },
            {
              "expr": "pgxpool_idle_conns{app=\"payment-service\"}",
              "legendFormat": "Idle"
            },
            {
              "expr": "pgxpool_acquired_conns{app=\"payment-service\"}",
              "legendFormat": "Active"
            }
          ],
          "gridPos": {"h": 6, "w": 8, "x": 16, "y": 6}
        }
      ]
    },
    {
      "title": "Throughput",
      "panels": [
        {
          "title": "Total RPS by Endpoint",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "sum(rate(http_server_requests_total{app=\"payment-service\"}[1m])) by (endpoint)",
              "legendFormat": "{{endpoint}}"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "reqps"
            }
          },
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
        },
        {
          "title": "Avg Latency by Endpoint (ms)",
          "type": "timeseries",
          "datasource": "${prometheus}",
          "targets": [
            {
              "expr": "rate(http_server_requests_seconds_sum{app=\"payment-service\"}[1m]) / rate(http_server_requests_seconds_count{app=\"payment-service\"}[1m]) * 1000",
              "legendFormat": "{{endpoint}}"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ms"
            }
          },
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
        }
      ]
    }
  ]
}
